# .env.example — copy to .env and fill in your values
# NEVER commit your real .env to source control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Flutter uses these names through --dart-define.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_anon_key

# Next.js uses these aliases if this backend is shared with a web app.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# Client-review APK mode. Enables the three fixed demo logins documented in README.
CLIENT_DEMO_ACCESS=true

# ── Database (local Docker only) ──────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── JWT (local Docker only) ───────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-token-for-local-dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Payment (Phase 2 — Razorpay) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
# Server-side only. Required by Supabase Edge Functions, never compiled into the Flutter app.
RAZORPAY_KEY_SECRET=...

# ── Scheduled maintenance Edge Function ─────────────────────────────────────
MAINTENANCE_TOKEN=replace-with-a-long-random-secret

# ── Client/demo account provisioning ─────────────────────────────────────────
# Server-side only. Required by scripts/setup_client_demo_accounts.ps1.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# ── Node.js WS Server ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
